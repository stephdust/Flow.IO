{"ok":true,"module":"io/input/i01","docs":{"io/input/i01/binding_port":{"module":"io/input/i01","name":"binding_port","type":"UInt16","label":"Port physique I01","help":"Identifiant du port physique utilise par l'entree digitale I01. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"i1BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_input"},"io/input/i01/counter_total":{"module":"io/input/i01","name":"counter_total","source":"override","type":"Float","label":"Cumul compteur","help":"Valeur cumulée éditable pour I01 en mode compteur. Cette correction écrase immédiatement le total actuel du compteur, devient la nouvelle statistique long terme et est écrite immédiatement en NVS."},"io/input/i01/edge_mode":{"module":"io/input/i01","name":"edge_mode","type":"UInt8","label":"Mode de front I01","help":"Front a compter pour I01 en mode compteur (0=descendant, 1=montant, 2=les deux).","var":"i1EdgeModeVar_","source":"cfgdoc","enum_set":"flowio_edge_mode"},"io/input/i01/i01_active_high":{"module":"io/input/i01","name":"i01_active_high","type":"Bool","label":"Actif a 1 I01","help":"Si active, l'entrée I01 est consideree active a l'etat haut.","var":"i1ActiveHighVar_","source":"auto-hint"},"io/input/i01/i01_c0":{"module":"io/input/i01","name":"i01_c0","type":"Float","label":"Coefficient C0 I01","help":"Coefficient multiplicateur applique au nombre d'impulsions de I01 en mode compteur. Il convertit les impulsions brutes en valeur cumulee publiee. Formule: value = c0 * impulsions.","var":"i1C0Var_","source":"auto-hint"},"io/input/i01/i01_name":{"module":"io/input/i01","name":"i01_name","type":"CharArray","label":"Nom entrée I01","help":"Nom lisible de l'entrée digitale I01.","var":"i1NameVar_","source":"auto-hint"},"io/input/i01/i01_prec":{"module":"io/input/i01","name":"i01_prec","type":"Int32","label":"Precision I01","help":"Nombre de decimales conservees pour la valeur calculee de I01 en mode compteur.","var":"i1PrecVar_","source":"auto-hint","unit":"digits"},"io/input/i01/i01_pull_mode":{"enum_set":"io_digital_pull_mode"},"io/input/i01/mode":{"type":"UInt8","label":"Mode entrée I01","help":"Choisit le type de fonctionnement de I01 (Etat ou Compteur d'Impulsion). Changement pris en compte au redemarrage.","enum_set":"flowio_digital_input_mode"}},"meta":{}}