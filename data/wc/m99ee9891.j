{"ok":true,"module":"io/input/a09","docs":{"io/input/a09/a09_c0":{"module":"io/input/a09","name":"a09_c0","type":"Float","label":"Coefficient C0 A09","help":"Coefficient multiplicateur de calibration pour A09. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a09","source":"synthetic-analog"},"io/input/a09/a09_c1":{"module":"io/input/a09","name":"a09_c1","type":"Float","label":"Offset C1 A09","help":"Offset de calibration pour A09. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a09","source":"synthetic-analog"},"io/input/a09/a09_name":{"module":"io/input/a09","name":"a09_name","type":"CharArray","label":"Nom entrée A09","help":"Nom lisible de l'entrée analogique A09.","var":"a09","source":"synthetic-analog"},"io/input/a09/a09_prec":{"module":"io/input/a09","name":"a09_prec","type":"Int32","label":"Precision A09","help":"Nombre de décimales conservées pour A09.","var":"a09","source":"synthetic-analog","unit":"digits"},"io/input/a09/binding_port":{"module":"io/input/a09","name":"binding_port","type":"UInt16","label":"Port physique A09","help":"Identifiant du port physique utilise par A09. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a09","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"}},"meta":{}}