{"ok":true,"module":"io/input/a00","docs":{"io/input/a00/a00_c0":{"module":"io/input/a00","name":"a00_c0","type":"Float","label":"Coefficient C0 A00","help":"Coefficient multiplicateur de calibration pour A00. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a00","source":"synthetic-analog"},"io/input/a00/a00_c1":{"module":"io/input/a00","name":"a00_c1","type":"Float","label":"Offset C1 A00","help":"Offset de calibration pour A00. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a00","source":"synthetic-analog"},"io/input/a00/a00_name":{"module":"io/input/a00","name":"a00_name","type":"CharArray","label":"Nom entrée A00","help":"Nom lisible de l'entrée analogique A00.","var":"a00","source":"synthetic-analog"},"io/input/a00/a00_prec":{"module":"io/input/a00","name":"a00_prec","type":"Int32","label":"Precision A00","help":"Nombre de décimales conservées pour A00.","var":"a00","source":"synthetic-analog","unit":"digits"},"io/input/a00/binding_port":{"module":"io/input/a00","name":"binding_port","type":"UInt16","label":"Port physique A00","help":"Identifiant du port physique utilise par A00. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a00","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"},"io/input/a00/a00_source":{"enum_set":"io_analog_source"}},"meta":{}}