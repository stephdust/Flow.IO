{"ok":true,"module":"io/input/a00","docs":{"io/input/a00/a00_c0":{"type":"Float","label_t":"cfgdocs.io.input.a00.a00_c0.label","help_t":"cfgdocs.io.input.a00.a00_c0.help","label":"Coefficient C0 A00","label_i18n":"cfgdocs.io.input.a00.a00_c0.label","help":"Coefficient multiplicateur de calibration pour A00. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","help_i18n":"cfgdocs.io.input.a00.a00_c0.help"},"io/input/a00/a00_c1":{"type":"Float","label_t":"cfgdocs.io.input.a00.a00_c1.label","help_t":"cfgdocs.io.input.a00.a00_c1.help","label":"Offset C1 A00","label_i18n":"cfgdocs.io.input.a00.a00_c1.label","help":"Offset de calibration pour A00. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","help_i18n":"cfgdocs.io.input.a00.a00_c1.help"},"io/input/a00/a00_name":{"type":"CharArray","label_t":"cfgdocs.io.input.a00.a00_name.label","help_t":"cfgdocs.io.input.a00.a00_name.help","label":"Nom entrée A00","label_i18n":"cfgdocs.io.input.a00.a00_name.label","help":"Nom lisible de l'entrée analogique A00.","help_i18n":"cfgdocs.io.input.a00.a00_name.help"},"io/input/a00/a00_prec":{"type":"Int32","label_t":"cfgdocs.io.input.a00.a00_prec.label","help_t":"cfgdocs.io.input.a00.a00_prec.help","unit":"digits","label":"Precision A00","label_i18n":"cfgdocs.io.input.a00.a00_prec.label","help":"Nombre de décimales conservées pour A00.","help_i18n":"cfgdocs.io.input.a00.a00_prec.help"},"io/input/a00/binding_port":{"type":"UInt16","label_t":"cfgdocs.io.input.a00.binding_port.label","help_t":"cfgdocs.io.input.a00.binding_port.help","enum_set":"flowio_binding_port_analog","label":"Port physique A00","label_i18n":"cfgdocs.io.input.a00.binding_port.label","help":"Identifiant du port physique utilise par A00. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","help_i18n":"cfgdocs.io.input.a00.binding_port.help"},"io/input/a00/a00_source":{"enum_set":"io_analog_source"}},"meta":{}}