{"ok":true,"module":"io/input/a10","docs":{"io/input/a10/a10_c0":{"module":"io/input/a10","name":"a10_c0","type":"Float","label":"Coefficient C0 A10","help":"Coefficient multiplicateur de calibration pour A10. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a10","source":"synthetic-analog"},"io/input/a10/a10_c1":{"module":"io/input/a10","name":"a10_c1","type":"Float","label":"Offset C1 A10","help":"Offset de calibration pour A10. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a10","source":"synthetic-analog"},"io/input/a10/a10_name":{"module":"io/input/a10","name":"a10_name","type":"CharArray","label":"Nom entrée A10","help":"Nom lisible de l'entrée analogique A10.","var":"a10","source":"synthetic-analog"},"io/input/a10/a10_prec":{"module":"io/input/a10","name":"a10_prec","type":"Int32","label":"Precision A10","help":"Nombre de décimales conservées pour A10.","var":"a10","source":"synthetic-analog","unit":"digits"},"io/input/a10/binding_port":{"module":"io/input/a10","name":"binding_port","type":"UInt16","label":"Port physique A10","help":"Identifiant du port physique utilise par A10. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a10","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"}},"meta":{}}