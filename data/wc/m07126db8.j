{"ok":true,"module":"io/input/i02","docs":{"io/input/i02/binding_port":{"module":"io/input/i02","name":"binding_port","type":"UInt16","label":"Port physique I02","help":"Identifiant du port physique utilise par l'entree digitale I02. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"i2BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_input"},"io/input/i02/counter_total":{"module":"io/input/i02","name":"counter_total","source":"override","type":"Float","label":"Cumul compteur","help":"Valeur cumulée éditable pour I02 en mode compteur. Cette correction écrase immédiatement le total actuel du compteur, devient la nouvelle statistique long terme et est écrite immédiatement en NVS."},"io/input/i02/edge_mode":{"module":"io/input/i02","name":"edge_mode","type":"UInt8","label":"Mode de front I02","help":"Front a compter pour I02 en mode compteur (0=descendant, 1=montant, 2=les deux).","var":"i2EdgeModeVar_","source":"cfgdoc","enum_set":"flowio_edge_mode"},"io/input/i02/i02_active_high":{"module":"io/input/i02","name":"i02_active_high","type":"Bool","label":"Actif a 1 I02","help":"Si active, l'entrée I02 est consideree active a l'etat haut.","var":"i2ActiveHighVar_","source":"auto-hint"},"io/input/i02/i02_c0":{"module":"io/input/i02","name":"i02_c0","type":"Float","label":"Coefficient C0 I02","help":"Coefficient multiplicateur applique au nombre d'impulsions de I02 en mode compteur. Il convertit les impulsions brutes en valeur cumulee publiee. Formule: value = c0 * impulsions.","var":"i2C0Var_","source":"auto-hint"},"io/input/i02/i02_name":{"module":"io/input/i02","name":"i02_name","type":"CharArray","label":"Nom entrée I02","help":"Nom lisible de l'entrée digitale I02.","var":"i2NameVar_","source":"auto-hint"},"io/input/i02/i02_prec":{"module":"io/input/i02","name":"i02_prec","type":"Int32","label":"Precision I02","help":"Nombre de decimales conservees pour la valeur calculee de I02 en mode compteur.","var":"i2PrecVar_","source":"auto-hint","unit":"digits"},"io/input/i02/i02_pull_mode":{"enum_set":"io_digital_pull_mode"},"io/input/i02/mode":{"type":"UInt8","label":"Mode entrée I02","help":"Choisit le type de fonctionnement de I02 (Etat ou Compteur d'Impulsion). Changement pris en compte au redemarrage.","enum_set":"flowio_digital_input_mode"}},"meta":{}}