{"ok":true,"module":"io/output/d05","docs":{"io/output/d05/binding_port":{"module":"io/output/d05","name":"binding_port","type":"UInt16","label":"Port physique D05","help":"Identifiant du port physique pilote par la sortie D05. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"d5BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_output"},"io/output/d05/d05_active_high":{"module":"io/output/d05","name":"d05_active_high","type":"Bool","label":"Actif a 1 D05","help":"Si vrai, D05 est active à l'état haut; sinon active-bas.","var":"d5ActiveHighVar_","source":"auto-hint"},"io/output/d05/d05_initial_on":{"module":"io/output/d05","name":"d05_initial_on","type":"Bool","label":"État initial ON D05","help":"État appliqué au démarrage pour la sortie D05.","var":"d5InitialOnVar_","source":"auto-hint"},"io/output/d05/d05_momentary":{"module":"io/output/d05","name":"d05_momentary","type":"Bool","label":"Mode impulsion D05","help":"Active un fonctionnement impulsionnel pour D05.","var":"d5MomentaryVar_","source":"auto-hint"},"io/output/d05/d05_name":{"module":"io/output/d05","name":"d05_name","type":"CharArray","label":"Nom sortie D05","help":"Nom lisible de la sortie digitale D05.","var":"d5NameVar_","source":"auto-hint"},"io/output/d05/d05_pulse_ms":{"module":"io/output/d05","name":"d05_pulse_ms","type":"Int32","label":"Durée impulsion D05 (ms)","help":"Durée de l'impulsion automatique de D05.","var":"d5PulseVar_","source":"auto-hint","unit":"ms"}},"meta":{}}