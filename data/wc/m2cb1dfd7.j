{"ok":true,"module":"io/output/d05","docs":{"io/output/d05/binding_port":{"type":"UInt16","label_t":"cfgdocs.io.output.d05.binding_port.label","help_t":"cfgdocs.io.output.d05.binding_port.help","enum_set":"flowio_binding_port_digital_output","label":"Port physique D05","label_i18n":"cfgdocs.io.output.d05.binding_port.label","help":"Identifiant du port physique pilote par la sortie D05. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","help_i18n":"cfgdocs.io.output.d05.binding_port.help"},"io/output/d05/d05_active_high":{"type":"Bool","label_t":"cfgdocs.io.output.d05.d05_active_high.label","help_t":"cfgdocs.io.output.d05.d05_active_high.help","label":"Actif a 1 D05","label_i18n":"cfgdocs.io.output.d05.d05_active_high.label","help":"Si vrai, D05 est active à l'état haut; sinon active-bas.","help_i18n":"cfgdocs.io.output.d05.d05_active_high.help"},"io/output/d05/d05_initial_on":{"type":"Bool","label_t":"cfgdocs.io.output.d05.d05_initial_on.label","help_t":"cfgdocs.io.output.d05.d05_initial_on.help","label":"État initial ON D05","label_i18n":"cfgdocs.io.output.d05.d05_initial_on.label","help":"État appliqué au démarrage pour la sortie D05.","help_i18n":"cfgdocs.io.output.d05.d05_initial_on.help"},"io/output/d05/d05_momentary":{"type":"Bool","label_t":"cfgdocs.io.output.d05.d05_momentary.label","help_t":"cfgdocs.io.output.d05.d05_momentary.help","label":"Mode impulsion D05","label_i18n":"cfgdocs.io.output.d05.d05_momentary.label","help":"Active un fonctionnement impulsionnel pour D05.","help_i18n":"cfgdocs.io.output.d05.d05_momentary.help"},"io/output/d05/d05_name":{"type":"CharArray","label_t":"cfgdocs.io.output.d05.d05_name.label","help_t":"cfgdocs.io.output.d05.d05_name.help","label":"Nom sortie D05","label_i18n":"cfgdocs.io.output.d05.d05_name.label","help":"Nom lisible de la sortie digitale D05.","help_i18n":"cfgdocs.io.output.d05.d05_name.help"},"io/output/d05/d05_pulse_ms":{"type":"Int32","label_t":"cfgdocs.io.output.d05.d05_pulse_ms.label","help_t":"cfgdocs.io.output.d05.d05_pulse_ms.help","unit":"ms","label":"Durée impulsion D05 (ms)","label_i18n":"cfgdocs.io.output.d05.d05_pulse_ms.label","help":"Durée de l'impulsion automatique de D05.","help_i18n":"cfgdocs.io.output.d05.d05_pulse_ms.help"}},"meta":{}}