{"ok":true,"module":"io/input/a14","docs":{"io/input/a14/a14_c0":{"module":"io/input/a14","name":"a14_c0","type":"Float","label":"Coefficient C0 A14","help":"Coefficient multiplicateur de calibration pour A14. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a14","source":"synthetic-analog"},"io/input/a14/a14_c1":{"module":"io/input/a14","name":"a14_c1","type":"Float","label":"Offset C1 A14","help":"Offset de calibration pour A14. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a14","source":"synthetic-analog"},"io/input/a14/a14_name":{"module":"io/input/a14","name":"a14_name","type":"CharArray","label":"Nom entrée A14","help":"Nom lisible de l'entrée analogique A14.","var":"a14","source":"synthetic-analog"},"io/input/a14/a14_prec":{"module":"io/input/a14","name":"a14_prec","type":"Int32","label":"Precision A14","help":"Nombre de décimales conservées pour A14.","var":"a14","source":"synthetic-analog","unit":"digits"},"io/input/a14/binding_port":{"module":"io/input/a14","name":"binding_port","type":"UInt16","label":"Port physique A14","help":"Identifiant du port physique utilise par A14. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a14","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"}},"meta":{}}