{"ok":true,"module":"io/input/a16","docs":{"io/input/a16/a16_c0":{"module":"io/input/a16","name":"a16_c0","type":"Float","label":"Coefficient C0 A16","help":"Coefficient multiplicateur de calibration pour A16. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a16","source":"synthetic-analog"},"io/input/a16/a16_c1":{"module":"io/input/a16","name":"a16_c1","type":"Float","label":"Offset C1 A16","help":"Offset de calibration pour A16. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a16","source":"synthetic-analog"},"io/input/a16/a16_name":{"module":"io/input/a16","name":"a16_name","type":"CharArray","label":"Nom entrée A16","help":"Nom lisible de l'entrée analogique A16.","var":"a16","source":"synthetic-analog"},"io/input/a16/a16_prec":{"module":"io/input/a16","name":"a16_prec","type":"Int32","label":"Precision A16","help":"Nombre de décimales conservées pour A16.","var":"a16","source":"synthetic-analog","unit":"digits"},"io/input/a16/binding_port":{"module":"io/input/a16","name":"binding_port","type":"UInt16","label":"Port physique A16","help":"Identifiant du port physique utilise par A16. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a16","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"}},"meta":{}}