{"ok":true,"module":"io/input/a12","docs":{"io/input/a12/a12_c0":{"module":"io/input/a12","name":"a12_c0","type":"Float","label":"Coefficient C0 A12","help":"Coefficient multiplicateur de calibration pour A12. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a12","source":"synthetic-analog"},"io/input/a12/a12_c1":{"module":"io/input/a12","name":"a12_c1","type":"Float","label":"Offset C1 A12","help":"Offset de calibration pour A12. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a12","source":"synthetic-analog"},"io/input/a12/a12_name":{"module":"io/input/a12","name":"a12_name","type":"CharArray","label":"Nom entrée A12","help":"Nom lisible de l'entrée analogique A12.","var":"a12","source":"synthetic-analog"},"io/input/a12/a12_prec":{"module":"io/input/a12","name":"a12_prec","type":"Int32","label":"Precision A12","help":"Nombre de décimales conservées pour A12.","var":"a12","source":"synthetic-analog","unit":"digits"},"io/input/a12/binding_port":{"module":"io/input/a12","name":"binding_port","type":"UInt16","label":"Port physique A12","help":"Identifiant du port physique utilise par A12. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a12","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"}},"meta":{}}