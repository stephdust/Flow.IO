{"ok":true,"module":"io/output/d02","docs":{"io/output/d02/binding_port":{"module":"io/output/d02","name":"binding_port","type":"UInt16","label":"Port physique D02","help":"Identifiant du port physique pilote par la sortie D02. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"d2BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_output"},"io/output/d02/d02_active_high":{"module":"io/output/d02","name":"d02_active_high","type":"Bool","label":"Actif a 1 D02","help":"Si vrai, D02 est active à l'état haut; sinon active-bas.","var":"d2ActiveHighVar_","source":"auto-hint"},"io/output/d02/d02_initial_on":{"module":"io/output/d02","name":"d02_initial_on","type":"Bool","label":"État initial ON D02","help":"État appliqué au démarrage pour la sortie D02.","var":"d2InitialOnVar_","source":"auto-hint"},"io/output/d02/d02_momentary":{"module":"io/output/d02","name":"d02_momentary","type":"Bool","label":"Mode impulsion D02","help":"Active un fonctionnement impulsionnel pour D02.","var":"d2MomentaryVar_","source":"auto-hint"},"io/output/d02/d02_name":{"module":"io/output/d02","name":"d02_name","type":"CharArray","label":"Nom sortie D02","help":"Nom lisible de la sortie digitale D02.","var":"d2NameVar_","source":"auto-hint"},"io/output/d02/d02_pulse_ms":{"module":"io/output/d02","name":"d02_pulse_ms","type":"Int32","label":"Durée impulsion D02 (ms)","help":"Durée de l'impulsion automatique de D02.","var":"d2PulseVar_","source":"auto-hint","unit":"ms"}},"meta":{}}