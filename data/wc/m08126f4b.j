{"ok":true,"module":"io/input/i03","docs":{"io/input/i03/binding_port":{"module":"io/input/i03","name":"binding_port","type":"UInt16","label":"Port physique I03","help":"Identifiant du port physique utilise par l'entree digitale I03. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"i3BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_input"},"io/input/i03/counter_total":{"module":"io/input/i03","name":"counter_total","source":"override","type":"Float","label":"Cumul compteur","help":"Valeur cumulée éditable pour I03 en mode compteur. Cette correction écrase immédiatement le total actuel du compteur, devient la nouvelle statistique long terme et est écrite immédiatement en NVS."},"io/input/i03/edge_mode":{"module":"io/input/i03","name":"edge_mode","type":"UInt8","label":"Mode de front I03","help":"Front a compter pour I03 en mode compteur (0=descendant, 1=montant, 2=les deux).","var":"i3EdgeModeVar_","source":"cfgdoc","enum_set":"flowio_edge_mode"},"io/input/i03/i03_active_high":{"module":"io/input/i03","name":"i03_active_high","type":"Bool","label":"Actif a 1 I03","help":"Si active, l'entrée I03 est consideree active a l'etat haut.","var":"i3ActiveHighVar_","source":"auto-hint"},"io/input/i03/i03_c0":{"module":"io/input/i03","name":"i03_c0","type":"Float","label":"Coefficient C0 I03","help":"Coefficient multiplicateur applique au nombre d'impulsions de I03 en mode compteur. Il convertit les impulsions brutes en valeur cumulee publiee. Formule: value = c0 * impulsions.","var":"i3C0Var_","source":"auto-hint"},"io/input/i03/i03_name":{"module":"io/input/i03","name":"i03_name","type":"CharArray","label":"Nom entrée I03","help":"Nom lisible de l'entrée digitale I03.","var":"i3NameVar_","source":"auto-hint"},"io/input/i03/i03_prec":{"module":"io/input/i03","name":"i03_prec","type":"Int32","label":"Precision I03","help":"Nombre de decimales conservees pour la valeur calculee de I03 en mode compteur.","var":"i3PrecVar_","source":"auto-hint","unit":"digits"},"io/input/i03/i03_pull_mode":{"enum_set":"io_digital_pull_mode"},"io/input/i03/mode":{"type":"UInt8","label":"Mode entrée I03","help":"Choisit le type de fonctionnement de I03 (Etat ou Compteur d'Impulsion). Changement pris en compte au redemarrage.","enum_set":"flowio_digital_input_mode"}},"meta":{}}