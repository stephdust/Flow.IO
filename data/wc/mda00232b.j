{"ok":true,"module":"poollogic/mode","docs":{"poollogic/mode/auto_mode":{"module":"poollogic/mode","name":"auto_mode","type":"Bool","label":"Mode auto global","help":"Active le pilotage automatique global de la piscine.","var":"autoModeVar_","source":"cfgdoc-alias"},"poollogic/mode/elec_mode":{"module":"poollogic/mode","name":"elec_mode","type":"Bool","label":"Electrolyse active","help":"Active la logique electrolyse. En auto, elle ne peut tourner que si la filtration est active (fenêtre horaire filtration), après délai et température mini.","var":"electrolyseModeVar_","source":"cfgdoc-alias"},"poollogic/mode/elec_run":{"module":"poollogic/mode","name":"elec_run","type":"Bool","label":"Electrolyse en service","help":"Choisit le mode de pilotage: OFF=marche non asservie (selon filtration+délai+température). ON=marche asservie ORP (démarre sous 90% de consigne, s'arrête à la consigne).","var":"electroRunModeVar_","source":"cfgdoc-alias"},"poollogic/mode/enabled":{"module":"poollogic/mode","name":"enabled","type":"Bool","label":"PoolLogic actif","help":"Active ou désactive les automatismes PoolLogic.","var":"enabledVar_","source":"cfgdoc-alias"},"poollogic/mode/heater_auto_mode":{"module":"poollogic/mode","name":"heater_auto_mode","type":"Bool","label":"Mode auto chauffage","help":"Active la régulation automatique de la température d'eau via le chauffage.","var":"heaterAutoModeVar_","source":"cfgdoc-alias"},"poollogic/mode/orp_auto_mode":{"module":"poollogic/mode","name":"orp_auto_mode","type":"Bool","label":"Mode auto ORP","help":"Active la régulation automatique ORP/chlore.","var":"orpAutoModeVar_","source":"cfgdoc-alias"},"poollogic/mode/ph_auto_mode":{"module":"poollogic/mode","name":"ph_auto_mode","type":"Bool","label":"Mode auto pH","help":"Active la régulation automatique du pH.","var":"phAutoModeVar_","source":"cfgdoc-alias"},"poollogic/mode/ph_dose_plus":{"module":"poollogic/mode","name":"ph_dose_plus","type":"Bool","label":"Injection pH+","help":"Si activé, la pompe pH injecte du pH+ (sinon pH-).","var":"phDosePlusVar_","source":"cfgdoc-alias"},"poollogic/mode/winter_mode":{"module":"poollogic/mode","name":"winter_mode","type":"Bool","label":"Mode hiver force","help":"Force le fonctionnement en mode hiver (anti-gel).","var":"winterModeVar_","source":"cfgdoc-alias"}},"meta":{}}