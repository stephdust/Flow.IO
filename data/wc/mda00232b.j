{"ok":true,"module":"poollogic/mode","docs":{"poollogic/mode/auto_mode":{"type":"Bool","label_t":"cfgdocs.poollogic.mode.auto_mode.label","help_t":"cfgdocs.poollogic.mode.auto_mode.help","label":"Mode auto global","label_i18n":"cfgdocs.poollogic.mode.auto_mode.label","help":"Active le pilotage automatique global de la piscine.","help_i18n":"cfgdocs.poollogic.mode.auto_mode.help"},"poollogic/mode/elec_mode":{"type":"Bool","label_t":"cfgdocs.poollogic.mode.elec_mode.label","help_t":"cfgdocs.poollogic.mode.elec_mode.help","label":"Electrolyse active","label_i18n":"cfgdocs.poollogic.mode.elec_mode.label","help":"Active la logique electrolyse. En auto, elle ne peut tourner que si la filtration est active (fenêtre horaire filtration), après délai et température mini.","help_i18n":"cfgdocs.poollogic.mode.elec_mode.help"},"poollogic/mode/elec_run":{"type":"Bool","label_t":"cfgdocs.poollogic.mode.elec_run.label","help_t":"cfgdocs.poollogic.mode.elec_run.help","label":"Electrolyse en service","label_i18n":"cfgdocs.poollogic.mode.elec_run.label","help":"Choisit le mode de pilotage: OFF=marche non asservie (selon filtration+délai+température). ON=marche asservie ORP (démarre sous 90% de consigne, s'arrête à la consigne).","help_i18n":"cfgdocs.poollogic.mode.elec_run.help"},"poollogic/mode/enabled":{"type":"Bool","label_t":"cfgdocs.poollogic.mode.enabled.label","help_t":"cfgdocs.poollogic.mode.enabled.help","label":"PoolLogic actif","label_i18n":"cfgdocs.poollogic.mode.enabled.label","help":"Active ou désactive les automatismes PoolLogic.","help_i18n":"cfgdocs.poollogic.mode.enabled.help"},"poollogic/mode/heater_auto_mode":{"type":"Bool","label_t":"cfgdocs.poollogic.mode.heater_auto_mode.label","help_t":"cfgdocs.poollogic.mode.heater_auto_mode.help","label":"Mode auto chauffage","label_i18n":"cfgdocs.poollogic.mode.heater_auto_mode.label","help":"Active la régulation automatique de la température d'eau via le chauffage.","help_i18n":"cfgdocs.poollogic.mode.heater_auto_mode.help"},"poollogic/mode/orp_auto_mode":{"type":"Bool","label_t":"cfgdocs.poollogic.mode.orp_auto_mode.label","help_t":"cfgdocs.poollogic.mode.orp_auto_mode.help","label":"Mode auto ORP","label_i18n":"cfgdocs.poollogic.mode.orp_auto_mode.label","help":"Active la régulation automatique ORP/chlore.","help_i18n":"cfgdocs.poollogic.mode.orp_auto_mode.help"},"poollogic/mode/ph_auto_mode":{"type":"Bool","label_t":"cfgdocs.poollogic.mode.ph_auto_mode.label","help_t":"cfgdocs.poollogic.mode.ph_auto_mode.help","label":"Mode auto pH","label_i18n":"cfgdocs.poollogic.mode.ph_auto_mode.label","help":"Active la régulation automatique du pH.","help_i18n":"cfgdocs.poollogic.mode.ph_auto_mode.help"},"poollogic/mode/ph_dose_plus":{"type":"Bool","label_t":"cfgdocs.poollogic.mode.ph_dose_plus.label","help_t":"cfgdocs.poollogic.mode.ph_dose_plus.help","label":"Injection pH+","label_i18n":"cfgdocs.poollogic.mode.ph_dose_plus.label","help":"Si activé, la pompe pH injecte du pH+ (sinon pH-).","help_i18n":"cfgdocs.poollogic.mode.ph_dose_plus.help"},"poollogic/mode/winter_mode":{"type":"Bool","label_t":"cfgdocs.poollogic.mode.winter_mode.label","help_t":"cfgdocs.poollogic.mode.winter_mode.help","label":"Mode hiver force","label_i18n":"cfgdocs.poollogic.mode.winter_mode.label","help":"Force le fonctionnement en mode hiver (anti-gel).","help_i18n":"cfgdocs.poollogic.mode.winter_mode.help"}},"meta":{}}