{"ok":true,"module":"io/input/a08","docs":{"io/input/a08/a08_c0":{"module":"io/input/a08","name":"a08_c0","type":"Float","label":"Coefficient C0 A08","help":"Coefficient multiplicateur de calibration pour A08. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a08","source":"synthetic-analog"},"io/input/a08/a08_c1":{"module":"io/input/a08","name":"a08_c1","type":"Float","label":"Offset C1 A08","help":"Offset de calibration pour A08. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a08","source":"synthetic-analog"},"io/input/a08/a08_name":{"module":"io/input/a08","name":"a08_name","type":"CharArray","label":"Nom entrée A08","help":"Nom lisible de l'entrée analogique A08.","var":"a08","source":"synthetic-analog"},"io/input/a08/a08_prec":{"module":"io/input/a08","name":"a08_prec","type":"Int32","label":"Precision A08","help":"Nombre de décimales conservées pour A08.","var":"a08","source":"synthetic-analog","unit":"digits"},"io/input/a08/binding_port":{"module":"io/input/a08","name":"binding_port","type":"UInt16","label":"Port physique A08","help":"Identifiant du port physique utilise par A08. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a08","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"}},"meta":{}}