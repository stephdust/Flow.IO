{"ok":true,"module":"hmi/fcd_udp","docs":{"hmi/fcd_udp/enabled":{"type":"Bool","label_t":"cfgdocs.hmi.fcd_udp.enabled.label","help_t":"cfgdocs.hmi.fcd_udp.enabled.help","label":"Flow Connect Display UDP actif","label_i18n":"cfgdocs.hmi.fcd_udp.enabled.label","help":"Utilise un Flow Connect Display distant via UDP a la place du Nextion local.","help_i18n":"cfgdocs.hmi.fcd_udp.enabled.help"},"hmi/fcd_udp/token":{"type":"CharArray","label_t":"cfgdocs.hmi.fcd_udp.token.label","help_t":"cfgdocs.hmi.fcd_udp.token.help","label":"Token Flow Connect Display","label_i18n":"cfgdocs.hmi.fcd_udp.token.label","help":"Token partage optionnel. Si renseigne, le Flow Connect Display doit envoyer le meme token sous forme CRC.","help_i18n":"cfgdocs.hmi.fcd_udp.token.help"}},"meta":{}}