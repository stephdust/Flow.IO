{"ok":true,"module":"io/input/a02","docs":{"io/input/a02/a02_c0":{"module":"io/input/a02","name":"a02_c0","type":"Float","label":"Coefficient C0 A02","help":"Coefficient multiplicateur de calibration pour A02. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a02","source":"synthetic-analog"},"io/input/a02/a02_c1":{"module":"io/input/a02","name":"a02_c1","type":"Float","label":"Offset C1 A02","help":"Offset de calibration pour A02. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a02","source":"synthetic-analog"},"io/input/a02/a02_name":{"module":"io/input/a02","name":"a02_name","type":"CharArray","label":"Nom entrée A02","help":"Nom lisible de l'entrée analogique A02.","var":"a02","source":"synthetic-analog"},"io/input/a02/a02_prec":{"module":"io/input/a02","name":"a02_prec","type":"Int32","label":"Precision A02","help":"Nombre de décimales conservées pour A02.","var":"a02","source":"synthetic-analog","unit":"digits"},"io/input/a02/binding_port":{"module":"io/input/a02","name":"binding_port","type":"UInt16","label":"Port physique A02","help":"Identifiant du port physique utilise par A02. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a02","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"},"io/input/a02/a02_source":{"enum_set":"io_analog_source"}},"meta":{}}