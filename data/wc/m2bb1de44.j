{"ok":true,"module":"io/output/d04","docs":{"io/output/d04/binding_port":{"module":"io/output/d04","name":"binding_port","type":"UInt16","label":"Port physique D04","help":"Identifiant du port physique pilote par la sortie D04. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"d4BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_output"},"io/output/d04/d04_active_high":{"module":"io/output/d04","name":"d04_active_high","type":"Bool","label":"Actif a 1 D04","help":"Si vrai, D04 est active à l'état haut; sinon active-bas.","var":"d4ActiveHighVar_","source":"auto-hint"},"io/output/d04/d04_initial_on":{"module":"io/output/d04","name":"d04_initial_on","type":"Bool","label":"État initial ON D04","help":"État appliqué au démarrage pour la sortie D04.","var":"d4InitialOnVar_","source":"auto-hint"},"io/output/d04/d04_momentary":{"module":"io/output/d04","name":"d04_momentary","type":"Bool","label":"Mode impulsion D04","help":"Active un fonctionnement impulsionnel pour D04.","var":"d4MomentaryVar_","source":"auto-hint"},"io/output/d04/d04_name":{"module":"io/output/d04","name":"d04_name","type":"CharArray","label":"Nom sortie D04","help":"Nom lisible de la sortie digitale D04.","var":"d4NameVar_","source":"auto-hint"},"io/output/d04/d04_pulse_ms":{"module":"io/output/d04","name":"d04_pulse_ms","type":"Int32","label":"Durée impulsion D04 (ms)","help":"Durée de l'impulsion automatique de D04.","var":"d4PulseVar_","source":"auto-hint","unit":"ms"}},"meta":{}}