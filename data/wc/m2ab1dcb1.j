{"ok":true,"module":"io/output/d03","docs":{"io/output/d03/binding_port":{"module":"io/output/d03","name":"binding_port","type":"UInt16","label":"Port physique D03","help":"Identifiant du port physique pilote par la sortie D03. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"d3BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_output"},"io/output/d03/d03_active_high":{"module":"io/output/d03","name":"d03_active_high","type":"Bool","label":"Actif a 1 D03","help":"Si vrai, D03 est active à l'état haut; sinon active-bas.","var":"d3ActiveHighVar_","source":"auto-hint"},"io/output/d03/d03_initial_on":{"module":"io/output/d03","name":"d03_initial_on","type":"Bool","label":"État initial ON D03","help":"État appliqué au démarrage pour la sortie D03.","var":"d3InitialOnVar_","source":"auto-hint"},"io/output/d03/d03_momentary":{"module":"io/output/d03","name":"d03_momentary","type":"Bool","label":"Mode impulsion D03","help":"Active un fonctionnement impulsionnel pour D03.","var":"d3MomentaryVar_","source":"auto-hint"},"io/output/d03/d03_name":{"module":"io/output/d03","name":"d03_name","type":"CharArray","label":"Nom sortie D03","help":"Nom lisible de la sortie digitale D03.","var":"d3NameVar_","source":"auto-hint"},"io/output/d03/d03_pulse_ms":{"module":"io/output/d03","name":"d03_pulse_ms","type":"Int32","label":"Durée impulsion D03 (ms)","help":"Durée de l'impulsion automatique de D03.","var":"d3PulseVar_","source":"auto-hint","unit":"ms"}},"meta":{}}