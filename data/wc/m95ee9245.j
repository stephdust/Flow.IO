{"ok":true,"module":"io/input/a05","docs":{"io/input/a05/a05_c0":{"module":"io/input/a05","name":"a05_c0","type":"Float","label":"Coefficient C0 A05","help":"Coefficient multiplicateur de calibration pour A05. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a05","source":"synthetic-analog"},"io/input/a05/a05_c1":{"module":"io/input/a05","name":"a05_c1","type":"Float","label":"Offset C1 A05","help":"Offset de calibration pour A05. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a05","source":"synthetic-analog"},"io/input/a05/a05_name":{"module":"io/input/a05","name":"a05_name","type":"CharArray","label":"Nom entrée A05","help":"Nom lisible de l'entrée analogique A05.","var":"a05","source":"synthetic-analog"},"io/input/a05/a05_prec":{"module":"io/input/a05","name":"a05_prec","type":"Int32","label":"Precision A05","help":"Nombre de décimales conservées pour A05.","var":"a05","source":"synthetic-analog","unit":"digits"},"io/input/a05/binding_port":{"module":"io/input/a05","name":"binding_port","type":"UInt16","label":"Port physique A05","help":"Identifiant du port physique utilise par A05. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a05","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"},"io/input/a05/a05_source":{"enum_set":"io_analog_source"}},"meta":{}}