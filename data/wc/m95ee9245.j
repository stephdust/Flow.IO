{"ok":true,"module":"io/input/a05","docs":{"io/input/a05/a05_c0":{"type":"Float","label_t":"cfgdocs.io.input.a05.a05_c0.label","help_t":"cfgdocs.io.input.a05.a05_c0.help","label":"Coefficient C0 A05","label_i18n":"cfgdocs.io.input.a05.a05_c0.label","help":"Coefficient multiplicateur de calibration pour A05. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","help_i18n":"cfgdocs.io.input.a05.a05_c0.help"},"io/input/a05/a05_c1":{"type":"Float","label_t":"cfgdocs.io.input.a05.a05_c1.label","help_t":"cfgdocs.io.input.a05.a05_c1.help","label":"Offset C1 A05","label_i18n":"cfgdocs.io.input.a05.a05_c1.label","help":"Offset de calibration pour A05. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","help_i18n":"cfgdocs.io.input.a05.a05_c1.help"},"io/input/a05/a05_name":{"type":"CharArray","label_t":"cfgdocs.io.input.a05.a05_name.label","help_t":"cfgdocs.io.input.a05.a05_name.help","label":"Nom entrée A05","label_i18n":"cfgdocs.io.input.a05.a05_name.label","help":"Nom lisible de l'entrée analogique A05.","help_i18n":"cfgdocs.io.input.a05.a05_name.help"},"io/input/a05/a05_prec":{"type":"Int32","label_t":"cfgdocs.io.input.a05.a05_prec.label","help_t":"cfgdocs.io.input.a05.a05_prec.help","unit":"digits","label":"Precision A05","label_i18n":"cfgdocs.io.input.a05.a05_prec.label","help":"Nombre de décimales conservées pour A05.","help_i18n":"cfgdocs.io.input.a05.a05_prec.help"},"io/input/a05/binding_port":{"type":"UInt16","label_t":"cfgdocs.io.input.a05.binding_port.label","help_t":"cfgdocs.io.input.a05.binding_port.help","enum_set":"flowio_binding_port_analog","label":"Port physique A05","label_i18n":"cfgdocs.io.input.a05.binding_port.label","help":"Identifiant du port physique utilise par A05. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","help_i18n":"cfgdocs.io.input.a05.binding_port.help"},"io/input/a05/a05_source":{"enum_set":"io_analog_source"}},"meta":{}}