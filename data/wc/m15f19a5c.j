{"ok":true,"module":"io/input/a11","docs":{"io/input/a11/a11_c0":{"module":"io/input/a11","name":"a11_c0","type":"Float","label":"Coefficient C0 A11","help":"Coefficient multiplicateur de calibration pour A11. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a11","source":"synthetic-analog"},"io/input/a11/a11_c1":{"module":"io/input/a11","name":"a11_c1","type":"Float","label":"Offset C1 A11","help":"Offset de calibration pour A11. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a11","source":"synthetic-analog"},"io/input/a11/a11_name":{"module":"io/input/a11","name":"a11_name","type":"CharArray","label":"Nom entrée A11","help":"Nom lisible de l'entrée analogique A11.","var":"a11","source":"synthetic-analog"},"io/input/a11/a11_prec":{"module":"io/input/a11","name":"a11_prec","type":"Int32","label":"Precision A11","help":"Nombre de décimales conservées pour A11.","var":"a11","source":"synthetic-analog","unit":"digits"},"io/input/a11/binding_port":{"module":"io/input/a11","name":"binding_port","type":"UInt16","label":"Port physique A11","help":"Identifiant du port physique utilise par A11. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a11","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"}},"meta":{}}