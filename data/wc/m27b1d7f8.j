{"ok":true,"module":"io/output/d00","docs":{"io/output/d00/binding_port":{"module":"io/output/d00","name":"binding_port","type":"UInt16","label":"Port physique D00","help":"Identifiant du port physique pilote par la sortie D00. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"d0BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_output"},"io/output/d00/d00_active_high":{"module":"io/output/d00","name":"d00_active_high","type":"Bool","label":"Actif a 1 D00","help":"Si vrai, D00 est active à l'état haut; sinon active-bas.","var":"d0ActiveHighVar_","source":"auto-hint"},"io/output/d00/d00_initial_on":{"module":"io/output/d00","name":"d00_initial_on","type":"Bool","label":"État initial ON D00","help":"État appliqué au démarrage pour la sortie D00.","var":"d0InitialOnVar_","source":"auto-hint"},"io/output/d00/d00_momentary":{"module":"io/output/d00","name":"d00_momentary","type":"Bool","label":"Mode impulsion D00","help":"Active un fonctionnement impulsionnel pour D00.","var":"d0MomentaryVar_","source":"auto-hint"},"io/output/d00/d00_name":{"module":"io/output/d00","name":"d00_name","type":"CharArray","label":"Nom sortie D00","help":"Nom lisible de la sortie digitale D00.","var":"d0NameVar_","source":"auto-hint"},"io/output/d00/d00_pulse_ms":{"module":"io/output/d00","name":"d00_pulse_ms","type":"Int32","label":"Durée impulsion D00 (ms)","help":"Durée de l'impulsion automatique de D00.","var":"d0PulseVar_","source":"auto-hint","unit":"ms"}},"meta":{}}