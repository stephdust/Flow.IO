{"ok":true,"module":"io/input/i04","docs":{"io/input/i04/binding_port":{"module":"io/input/i04","name":"binding_port","type":"UInt16","label":"Port physique I04","help":"Identifiant du port physique utilise par l'entree digitale I04. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"i4BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_input"},"io/input/i04/counter_total":{"module":"io/input/i04","name":"counter_total","source":"override","type":"Float","label":"Cumul compteur","help":"Valeur cumulée éditable pour I04 en mode compteur. Cette correction écrase immédiatement le total actuel du compteur, devient la nouvelle statistique long terme et est écrite immédiatement en NVS."},"io/input/i04/edge_mode":{"module":"io/input/i04","name":"edge_mode","type":"UInt8","label":"Mode de front I04","help":"Front a compter pour I04 en mode compteur (0=descendant, 1=montant, 2=les deux).","var":"i4EdgeModeVar_","source":"cfgdoc","enum_set":"flowio_edge_mode"},"io/input/i04/i04_active_high":{"module":"io/input/i04","name":"i04_active_high","type":"Bool","label":"Actif a 1 I04","help":"Si active, l'entrée I04 est consideree active a l'etat haut.","var":"i4ActiveHighVar_","source":"auto-hint"},"io/input/i04/i04_c0":{"module":"io/input/i04","name":"i04_c0","type":"Float","label":"Coefficient C0 I04","help":"Coefficient multiplicateur applique au nombre d'impulsions de I04 en mode compteur. Il convertit les impulsions brutes en valeur cumulee publiee. Formule: value = c0 * impulsions.","var":"i4C0Var_","source":"auto-hint"},"io/input/i04/i04_name":{"module":"io/input/i04","name":"i04_name","type":"CharArray","label":"Nom entrée I04","help":"Nom lisible de l'entrée digitale I04.","var":"i4NameVar_","source":"auto-hint"},"io/input/i04/i04_prec":{"module":"io/input/i04","name":"i04_prec","type":"Int32","label":"Precision I04","help":"Nombre de decimales conservees pour la valeur calculee de I04 en mode compteur.","var":"i4PrecVar_","source":"auto-hint","unit":"digits"},"io/input/i04/i04_pull_mode":{"enum_set":"io_digital_pull_mode"},"io/input/i04/mode":{"type":"UInt8","label":"Mode entrée I04","help":"Choisit le type de fonctionnement de I04 (Etat ou Compteur d'Impulsion). Changement pris en compte au redemarrage.","enum_set":"flowio_digital_input_mode"}},"meta":{}}