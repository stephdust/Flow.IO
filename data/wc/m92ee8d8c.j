{"ok":true,"module":"io/input/a06","docs":{"io/input/a06/a06_c0":{"module":"io/input/a06","name":"a06_c0","type":"Float","label":"Coefficient C0 A06","help":"Coefficient multiplicateur de calibration pour A06. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a06","source":"synthetic-analog"},"io/input/a06/a06_c1":{"module":"io/input/a06","name":"a06_c1","type":"Float","label":"Offset C1 A06","help":"Offset de calibration pour A06. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a06","source":"synthetic-analog"},"io/input/a06/a06_name":{"module":"io/input/a06","name":"a06_name","type":"CharArray","label":"Nom entrée A06","help":"Nom lisible de l'entrée analogique A06.","var":"a06","source":"synthetic-analog"},"io/input/a06/a06_prec":{"module":"io/input/a06","name":"a06_prec","type":"Int32","label":"Precision A06","help":"Nombre de décimales conservées pour A06.","var":"a06","source":"synthetic-analog","unit":"digits"},"io/input/a06/binding_port":{"module":"io/input/a06","name":"binding_port","type":"UInt16","label":"Port physique A06","help":"Identifiant du port physique utilise par A06. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a06","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"}},"meta":{}}