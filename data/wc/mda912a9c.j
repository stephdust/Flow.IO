{"ok":true,"module":"elink/lcd","docs":{"elink/lcd/auto_off_60s":{"module":"elink/lcd","name":"auto_off_60s","type":"Bool","label":"Extinction auto ecran (60s)","help":"Si actif, le backlight s'eteint apres 60 secondes sans mouvement; sinon l'ecran reste allume.","var":"lcdAutoOffVar_","source":"cfgdoc"},"elink/lcd/motion_gpio":{"module":"elink/lcd","name":"motion_gpio","type":"Int32","label":"GPIO detecteur de mouvement","help":"GPIO du capteur de mouvement utilise pour rallumer l'ecran quand l'extinction auto est active.","var":"lcdMotionGpioVar_","source":"cfgdoc"}},"meta":{}}