{"ok":true,"module":"elink/lcd","docs":{"elink/lcd/auto_off_60s":{"type":"Bool","label_t":"cfgdocs.elink.lcd.auto_off_60s.label","help_t":"cfgdocs.elink.lcd.auto_off_60s.help","label":"Extinction auto ecran (60s)","label_i18n":"cfgdocs.elink.lcd.auto_off_60s.label","help":"Si actif, le backlight s'eteint apres 60 secondes sans mouvement; sinon l'ecran reste allume.","help_i18n":"cfgdocs.elink.lcd.auto_off_60s.help"},"elink/lcd/motion_gpio":{"type":"Int32","label_t":"cfgdocs.elink.lcd.motion_gpio.label","help_t":"cfgdocs.elink.lcd.motion_gpio.help","label":"GPIO detecteur de mouvement","label_i18n":"cfgdocs.elink.lcd.motion_gpio.label","help":"GPIO du capteur de mouvement utilise pour rallumer l'ecran quand l'extinction auto est active.","help_i18n":"cfgdocs.elink.lcd.motion_gpio.help"}},"meta":{}}