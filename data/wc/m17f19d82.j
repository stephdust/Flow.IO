{"ok":true,"module":"io/input/a13","docs":{"io/input/a13/a13_c0":{"type":"Float","label_t":"cfgdocs.io.input.a13.a13_c0.label","help_t":"cfgdocs.io.input.a13.a13_c0.help","label":"Coefficient C0 A13","label_i18n":"cfgdocs.io.input.a13.a13_c0.label","help":"Coefficient multiplicateur de calibration pour A13. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","help_i18n":"cfgdocs.io.input.a13.a13_c0.help"},"io/input/a13/a13_c1":{"type":"Float","label_t":"cfgdocs.io.input.a13.a13_c1.label","help_t":"cfgdocs.io.input.a13.a13_c1.help","label":"Offset C1 A13","label_i18n":"cfgdocs.io.input.a13.a13_c1.label","help":"Offset de calibration pour A13. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","help_i18n":"cfgdocs.io.input.a13.a13_c1.help"},"io/input/a13/a13_name":{"type":"CharArray","label_t":"cfgdocs.io.input.a13.a13_name.label","help_t":"cfgdocs.io.input.a13.a13_name.help","label":"Nom entrée A13","label_i18n":"cfgdocs.io.input.a13.a13_name.label","help":"Nom lisible de l'entrée analogique A13.","help_i18n":"cfgdocs.io.input.a13.a13_name.help"},"io/input/a13/a13_prec":{"type":"Int32","label_t":"cfgdocs.io.input.a13.a13_prec.label","help_t":"cfgdocs.io.input.a13.a13_prec.help","unit":"digits","label":"Precision A13","label_i18n":"cfgdocs.io.input.a13.a13_prec.label","help":"Nombre de décimales conservées pour A13.","help_i18n":"cfgdocs.io.input.a13.a13_prec.help"},"io/input/a13/binding_port":{"type":"UInt16","label_t":"cfgdocs.io.input.a13.binding_port.label","help_t":"cfgdocs.io.input.a13.binding_port.help","enum_set":"flowio_binding_port_analog","label":"Port physique A13","label_i18n":"cfgdocs.io.input.a13.binding_port.label","help":"Identifiant du port physique utilise par A13. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","help_i18n":"cfgdocs.io.input.a13.binding_port.help"}},"meta":{}}