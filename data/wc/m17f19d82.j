{"ok":true,"module":"io/input/a13","docs":{"io/input/a13/a13_c0":{"module":"io/input/a13","name":"a13_c0","type":"Float","label":"Coefficient C0 A13","help":"Coefficient multiplicateur de calibration pour A13. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a13","source":"synthetic-analog"},"io/input/a13/a13_c1":{"module":"io/input/a13","name":"a13_c1","type":"Float","label":"Offset C1 A13","help":"Offset de calibration pour A13. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a13","source":"synthetic-analog"},"io/input/a13/a13_name":{"module":"io/input/a13","name":"a13_name","type":"CharArray","label":"Nom entrée A13","help":"Nom lisible de l'entrée analogique A13.","var":"a13","source":"synthetic-analog"},"io/input/a13/a13_prec":{"module":"io/input/a13","name":"a13_prec","type":"Int32","label":"Precision A13","help":"Nombre de décimales conservées pour A13.","var":"a13","source":"synthetic-analog","unit":"digits"},"io/input/a13/binding_port":{"module":"io/input/a13","name":"binding_port","type":"UInt16","label":"Port physique A13","help":"Identifiant du port physique utilise par A13. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a13","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"}},"meta":{}}