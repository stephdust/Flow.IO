{"ok":true,"module":"__wildcard","docs":{"*/depends_on_mask":{"module":"*","name":"depends_on_mask","type":"uint8_t","label":"Masque dépendances","help":"Masque de dépendances inter-appareils.","var":"cfgDependsVar_","source":"cfgdoc-series"},"*/enabled":{"module":"*","name":"enabled","type":"bool","label":"Activation appareil","help":"Active ou désactive l'appareil du pool concerne.","var":"cfgEnabledVar_","source":"cfgdoc-series"},"*/flow_l_h":{"module":"*","name":"flow_l_h","type":"float","label":"Débit (L/h)","help":"Débit nominal en litres par heure pour le calcul d'injection.","var":"cfgFlowVar_","source":"cfgdoc-series","unit":"L/h"},"*/max_uptime_day_s":{"module":"*","name":"max_uptime_day_s","type":"int32_t","label":"Uptime max journalier (s)","help":"Temps maximal autorisé par jour pour l'appareil.","var":"cfgMaxUptimeVar_","source":"cfgdoc-series","unit":"s"},"*/metrics_blob":{"module":"*","name":"metrics_blob","type":"char","label":"Blob métriques","help":"État/métriques persistees de l'appareil pour reprise.","var":"cfgRuntimeVar_","source":"cfgdoc-series"},"*/tank_cap_ml":{"module":"*","name":"tank_cap_ml","type":"float","label":"Capacité cuve (mL)","help":"Capacité maximale de la cuve associée à l'appareil.","var":"cfgTankCapVar_","source":"cfgdoc-series","unit":"mL"},"*/tank_init_ml":{"module":"*","name":"tank_init_ml","type":"float","label":"Niveau initial cuve (mL)","help":"Volume initial de cuve après configuration/reset.","var":"cfgTankInitVar_","source":"cfgdoc-series","unit":"mL"}},"meta":{}}