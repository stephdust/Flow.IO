{"ok":true,"module":"io/input/a07","docs":{"io/input/a07/a07_c0":{"module":"io/input/a07","name":"a07_c0","type":"Float","label":"Coefficient C0 A07","help":"Coefficient multiplicateur de calibration pour A07. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a07","source":"synthetic-analog"},"io/input/a07/a07_c1":{"module":"io/input/a07","name":"a07_c1","type":"Float","label":"Offset C1 A07","help":"Offset de calibration pour A07. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a07","source":"synthetic-analog"},"io/input/a07/a07_name":{"module":"io/input/a07","name":"a07_name","type":"CharArray","label":"Nom entrée A07","help":"Nom lisible de l'entrée analogique A07.","var":"a07","source":"synthetic-analog"},"io/input/a07/a07_prec":{"module":"io/input/a07","name":"a07_prec","type":"Int32","label":"Precision A07","help":"Nombre de décimales conservées pour A07.","var":"a07","source":"synthetic-analog","unit":"digits"},"io/input/a07/binding_port":{"module":"io/input/a07","name":"binding_port","type":"UInt16","label":"Port physique A07","help":"Identifiant du port physique utilise par A07. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a07","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"}},"meta":{}}