{"ok":true,"module":"io/output/d01","docs":{"io/output/d01/binding_port":{"module":"io/output/d01","name":"binding_port","type":"UInt16","label":"Port physique D01","help":"Identifiant du port physique pilote par la sortie D01. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"d1BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_output"},"io/output/d01/d01_active_high":{"module":"io/output/d01","name":"d01_active_high","type":"Bool","label":"Actif a 1 D01","help":"Si vrai, D01 est active à l'état haut; sinon active-bas.","var":"d1ActiveHighVar_","source":"auto-hint"},"io/output/d01/d01_initial_on":{"module":"io/output/d01","name":"d01_initial_on","type":"Bool","label":"État initial ON D01","help":"État appliqué au démarrage pour la sortie D01.","var":"d1InitialOnVar_","source":"auto-hint"},"io/output/d01/d01_momentary":{"module":"io/output/d01","name":"d01_momentary","type":"Bool","label":"Mode impulsion D01","help":"Active un fonctionnement impulsionnel pour D01.","var":"d1MomentaryVar_","source":"auto-hint"},"io/output/d01/d01_name":{"module":"io/output/d01","name":"d01_name","type":"CharArray","label":"Nom sortie D01","help":"Nom lisible de la sortie digitale D01.","var":"d1NameVar_","source":"auto-hint"},"io/output/d01/d01_pulse_ms":{"module":"io/output/d01","name":"d01_pulse_ms","type":"Int32","label":"Durée impulsion D01 (ms)","help":"Durée de l'impulsion automatique de D01.","var":"d1PulseVar_","source":"auto-hint","unit":"ms"}},"meta":{}}