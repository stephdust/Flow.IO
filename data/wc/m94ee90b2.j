{"ok":true,"module":"io/input/a04","docs":{"io/input/a04/a04_c0":{"module":"io/input/a04","name":"a04_c0","type":"Float","label":"Coefficient C0 A04","help":"Coefficient multiplicateur de calibration pour A04. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a04","source":"synthetic-analog"},"io/input/a04/a04_c1":{"module":"io/input/a04","name":"a04_c1","type":"Float","label":"Offset C1 A04","help":"Offset de calibration pour A04. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a04","source":"synthetic-analog"},"io/input/a04/a04_name":{"module":"io/input/a04","name":"a04_name","type":"CharArray","label":"Nom entrée A04","help":"Nom lisible de l'entrée analogique A04.","var":"a04","source":"synthetic-analog"},"io/input/a04/a04_prec":{"module":"io/input/a04","name":"a04_prec","type":"Int32","label":"Precision A04","help":"Nombre de décimales conservées pour A04.","var":"a04","source":"synthetic-analog","unit":"digits"},"io/input/a04/binding_port":{"module":"io/input/a04","name":"binding_port","type":"UInt16","label":"Port physique A04","help":"Identifiant du port physique utilise par A04. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a04","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"},"io/input/a04/a04_source":{"enum_set":"io_analog_source"}},"meta":{}}