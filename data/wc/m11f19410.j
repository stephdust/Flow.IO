{"ok":true,"module":"io/input/a15","docs":{"io/input/a15/a15_c0":{"type":"Float","label_t":"cfgdocs.io.input.a15.a15_c0.label","help_t":"cfgdocs.io.input.a15.a15_c0.help","label":"Coefficient C0 A15","label_i18n":"cfgdocs.io.input.a15.a15_c0.label","help":"Coefficient multiplicateur de calibration pour A15. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","help_i18n":"cfgdocs.io.input.a15.a15_c0.help"},"io/input/a15/a15_c1":{"type":"Float","label_t":"cfgdocs.io.input.a15.a15_c1.label","help_t":"cfgdocs.io.input.a15.a15_c1.help","label":"Offset C1 A15","label_i18n":"cfgdocs.io.input.a15.a15_c1.label","help":"Offset de calibration pour A15. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","help_i18n":"cfgdocs.io.input.a15.a15_c1.help"},"io/input/a15/a15_name":{"type":"CharArray","label_t":"cfgdocs.io.input.a15.a15_name.label","help_t":"cfgdocs.io.input.a15.a15_name.help","label":"Nom entrée A15","label_i18n":"cfgdocs.io.input.a15.a15_name.label","help":"Nom lisible de l'entrée analogique A15.","help_i18n":"cfgdocs.io.input.a15.a15_name.help"},"io/input/a15/a15_prec":{"type":"Int32","label_t":"cfgdocs.io.input.a15.a15_prec.label","help_t":"cfgdocs.io.input.a15.a15_prec.help","unit":"digits","label":"Precision A15","label_i18n":"cfgdocs.io.input.a15.a15_prec.label","help":"Nombre de décimales conservées pour A15.","help_i18n":"cfgdocs.io.input.a15.a15_prec.help"},"io/input/a15/binding_port":{"type":"UInt16","label_t":"cfgdocs.io.input.a15.binding_port.label","help_t":"cfgdocs.io.input.a15.binding_port.help","enum_set":"flowio_binding_port_analog","label":"Port physique A15","label_i18n":"cfgdocs.io.input.a15.binding_port.label","help":"Identifiant du port physique utilise par A15. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","help_i18n":"cfgdocs.io.input.a15.binding_port.help"}},"meta":{}}