{"ok":true,"module":"io/input/a15","docs":{"io/input/a15/a15_c0":{"module":"io/input/a15","name":"a15_c0","type":"Float","label":"Coefficient C0 A15","help":"Coefficient multiplicateur de calibration pour A15. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a15","source":"synthetic-analog"},"io/input/a15/a15_c1":{"module":"io/input/a15","name":"a15_c1","type":"Float","label":"Offset C1 A15","help":"Offset de calibration pour A15. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a15","source":"synthetic-analog"},"io/input/a15/a15_name":{"module":"io/input/a15","name":"a15_name","type":"CharArray","label":"Nom entrée A15","help":"Nom lisible de l'entrée analogique A15.","var":"a15","source":"synthetic-analog"},"io/input/a15/a15_prec":{"module":"io/input/a15","name":"a15_prec","type":"Int32","label":"Precision A15","help":"Nombre de décimales conservées pour A15.","var":"a15","source":"synthetic-analog","unit":"digits"},"io/input/a15/binding_port":{"module":"io/input/a15","name":"binding_port","type":"UInt16","label":"Port physique A15","help":"Identifiant du port physique utilise par A15. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a15","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"}},"meta":{}}