{"ok":true,"module":"io/input/a01","docs":{"io/input/a01/a01_c0":{"module":"io/input/a01","name":"a01_c0","type":"Float","label":"Coefficient C0 A01","help":"Coefficient multiplicateur de calibration pour A01. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a01","source":"synthetic-analog"},"io/input/a01/a01_c1":{"module":"io/input/a01","name":"a01_c1","type":"Float","label":"Offset C1 A01","help":"Offset de calibration pour A01. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a01","source":"synthetic-analog"},"io/input/a01/a01_name":{"module":"io/input/a01","name":"a01_name","type":"CharArray","label":"Nom entrée A01","help":"Nom lisible de l'entrée analogique A01.","var":"a01","source":"synthetic-analog"},"io/input/a01/a01_prec":{"module":"io/input/a01","name":"a01_prec","type":"Int32","label":"Precision A01","help":"Nombre de décimales conservées pour A01.","var":"a01","source":"synthetic-analog","unit":"digits"},"io/input/a01/binding_port":{"module":"io/input/a01","name":"binding_port","type":"UInt16","label":"Port physique A01","help":"Identifiant du port physique utilise par A01. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a01","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"},"io/input/a01/a01_source":{"enum_set":"io_analog_source"}},"meta":{}}