{"ok":true,"module":"io/input/i00","docs":{"io/input/i00/binding_port":{"module":"io/input/i00","name":"binding_port","type":"UInt16","label":"Port physique I00","help":"Identifiant du port physique utilise par l'entree digitale I00. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"i0BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_input"},"io/input/i00/counter_total":{"module":"io/input/i00","name":"counter_total","source":"override","type":"Float","label":"Cumul compteur","help":"Valeur cumulée éditable pour I00 en mode compteur. Cette correction écrase immédiatement le total actuel du compteur, devient la nouvelle statistique long terme et est écrite immédiatement en NVS."},"io/input/i00/edge_mode":{"module":"io/input/i00","name":"edge_mode","type":"UInt8","label":"Mode de front I00","help":"Front a compter pour I00 en mode compteur (0=descendant, 1=montant, 2=les deux).","var":"i0EdgeModeVar_","source":"cfgdoc","enum_set":"flowio_edge_mode"},"io/input/i00/i00_active_high":{"module":"io/input/i00","name":"i00_active_high","type":"Bool","label":"Actif a 1 I00","help":"Si active, l'entrée I00 est consideree active a l'etat haut.","var":"i0ActiveHighVar_","source":"auto-hint"},"io/input/i00/i00_c0":{"module":"io/input/i00","name":"i00_c0","type":"Float","label":"Coefficient C0 I00","help":"Coefficient multiplicateur applique au nombre d'impulsions de I00 en mode compteur. Il convertit les impulsions brutes en valeur cumulee publiee. Formule: value = c0 * impulsions.","var":"i0C0Var_","source":"auto-hint"},"io/input/i00/i00_name":{"module":"io/input/i00","name":"i00_name","type":"CharArray","label":"Nom entrée I00","help":"Nom lisible de l'entrée digitale I00.","var":"i0NameVar_","source":"auto-hint"},"io/input/i00/i00_prec":{"module":"io/input/i00","name":"i00_prec","type":"Int32","label":"Precision I00","help":"Nombre de decimales conservees pour la valeur calculee de I00 en mode compteur.","var":"i0PrecVar_","source":"auto-hint","unit":"digits"},"io/input/i00/i00_pull_mode":{"enum_set":"io_digital_pull_mode"},"io/input/i00/mode":{"type":"UInt8","label":"Mode entrée I00","help":"Choisit le type de fonctionnement de I00 (Etat ou Compteur d'Impulsion). Changement pris en compte au redemarrage.","enum_set":"flowio_digital_input_mode"}},"meta":{}}