{"ok":true,"module":"io/output/d07","docs":{"io/output/d07/binding_port":{"module":"io/output/d07","name":"binding_port","type":"UInt16","label":"Port physique D07","help":"Identifiant du port physique pilote par la sortie D07. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"d7BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_output"},"io/output/d07/d07_active_high":{"module":"io/output/d07","name":"d07_active_high","type":"Bool","label":"Actif a 1 D07","help":"Si vrai, D07 est active à l'état haut; sinon active-bas.","var":"d7ActiveHighVar_","source":"auto-hint"},"io/output/d07/d07_initial_on":{"module":"io/output/d07","name":"d07_initial_on","type":"Bool","label":"État initial ON D07","help":"État appliqué au démarrage pour la sortie D07.","var":"d7InitialOnVar_","source":"auto-hint"},"io/output/d07/d07_momentary":{"module":"io/output/d07","name":"d07_momentary","type":"Bool","label":"Mode impulsion D07","help":"Active un fonctionnement impulsionnel pour D07.","var":"d7MomentaryVar_","source":"auto-hint"},"io/output/d07/d07_name":{"module":"io/output/d07","name":"d07_name","type":"CharArray","label":"Nom sortie D07","help":"Nom lisible de la sortie digitale D07.","var":"d7NameVar_","source":"auto-hint"},"io/output/d07/d07_pulse_ms":{"module":"io/output/d07","name":"d07_pulse_ms","type":"Int32","label":"Durée impulsion D07 (ms)","help":"Durée de l'impulsion automatique de D07.","var":"d7PulseVar_","source":"auto-hint","unit":"ms"}},"meta":{}}