{"ok":true,"module":"io/input/a03","docs":{"io/input/a03/a03_c0":{"module":"io/input/a03","name":"a03_c0","type":"Float","label":"Coefficient C0 A03","help":"Coefficient multiplicateur de calibration pour A03. Il ajuste l'echelle de la mesure brute avant publication. Formule: value = c0 * input + c1.","var":"a03","source":"synthetic-analog"},"io/input/a03/a03_c1":{"module":"io/input/a03","name":"a03_c1","type":"Float","label":"Offset C1 A03","help":"Offset de calibration pour A03. Il ajoute un decalage a la mesure convertie pour corriger le zero ou appliquer une translation. Formule: value = c0 * input + c1.","var":"a03","source":"synthetic-analog"},"io/input/a03/a03_name":{"module":"io/input/a03","name":"a03_name","type":"CharArray","label":"Nom entrée A03","help":"Nom lisible de l'entrée analogique A03.","var":"a03","source":"synthetic-analog"},"io/input/a03/a03_prec":{"module":"io/input/a03","name":"a03_prec","type":"Int32","label":"Precision A03","help":"Nombre de décimales conservées pour A03.","var":"a03","source":"synthetic-analog","unit":"digits"},"io/input/a03/binding_port":{"module":"io/input/a03","name":"binding_port","type":"UInt16","label":"Port physique A03","help":"Identifiant du port physique utilise par A03. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"a03","source":"synthetic-analog","enum_set":"flowio_binding_port_analog"},"io/input/a03/a03_source":{"enum_set":"io_analog_source"}},"meta":{}}