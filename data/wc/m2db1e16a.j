{"ok":true,"module":"io/output/d06","docs":{"io/output/d06/binding_port":{"module":"io/output/d06","name":"binding_port","type":"UInt16","label":"Port physique D06","help":"Identifiant du port physique pilote par la sortie D06. La valeur reference un binding compile-time autorise, pas un numero de GPIO brut.","var":"d6BindingVar_","source":"cfgdoc","enum_set":"flowio_binding_port_digital_output"},"io/output/d06/d06_active_high":{"module":"io/output/d06","name":"d06_active_high","type":"Bool","label":"Actif a 1 D06","help":"Si vrai, D06 est active à l'état haut; sinon active-bas.","var":"d6ActiveHighVar_","source":"auto-hint"},"io/output/d06/d06_initial_on":{"module":"io/output/d06","name":"d06_initial_on","type":"Bool","label":"État initial ON D06","help":"État appliqué au démarrage pour la sortie D06.","var":"d6InitialOnVar_","source":"auto-hint"},"io/output/d06/d06_momentary":{"module":"io/output/d06","name":"d06_momentary","type":"Bool","label":"Mode impulsion D06","help":"Active un fonctionnement impulsionnel pour D06.","var":"d6MomentaryVar_","source":"auto-hint"},"io/output/d06/d06_name":{"module":"io/output/d06","name":"d06_name","type":"CharArray","label":"Nom sortie D06","help":"Nom lisible de la sortie digitale D06.","var":"d6NameVar_","source":"auto-hint"},"io/output/d06/d06_pulse_ms":{"module":"io/output/d06","name":"d06_pulse_ms","type":"Int32","label":"Durée impulsion D06 (ms)","help":"Durée de l'impulsion automatique de D06.","var":"d6PulseVar_","source":"auto-hint","unit":"ms"}},"meta":{}}